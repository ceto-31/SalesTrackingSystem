# backend/.htaccess
# CORS is handled in PHP (backend/middleware/auth.php) — do NOT set CORS
# headers here, otherwise responses will contain duplicate values.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Product images: serve from Railway S3 bucket or local disk.
    RewriteRule ^uploads/products/([a-f0-9]{32}\.(jpg|jpeg|png|webp|gif))$ api/uploads/serve.php?file=$1 [L,QSA,NC]
</IfModule>
